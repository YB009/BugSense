{
  "name": "@bugsense/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "clean:next": "node -e \"require('fs').rmSync('.next/dev', { recursive: true, force: true })\"",
    "predev": "pnpm run clean:next",
    "dev": "next dev --webpack -p 3005",
    "lint": "tsc --project tsconfig.json --noEmit",
    "start": "next start -p 3005",
    "test": "node -e \"console.log('No tests yet for dashboard')\"",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bugsense/types": "workspace:*",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.8.2"
  }
}
